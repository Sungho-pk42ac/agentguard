# AgentGuard self-hosting environment template.
# Copy to deploy/.env and replace every change-me-* value before production use.

# Public hostname for the Caddy proxy. Use localhost for local/dev HTTP.
DOMAIN=localhost

# Postgres database and owner role. The owner password is used only for boot-time migrations.
POSTGRES_DB=agentguard
POSTGRES_USER=agentguard_admin
POSTGRES_PASSWORD=change-me-owner-password

# Least-privilege runtime role password used by the API container.
POSTGRES_API_PASSWORD=change-me-api-password

# Legacy static viewer tokens: JSON object mapping token -> org id. Keep {} unless you need read-only legacy access.
AGENTGUARD_CP_VIEWER_KEYS={}

# Optional Slack/Teams incoming webhook URL for alerts. Leave empty to log alerts to stderr.
AGENTGUARD_CP_WEBHOOK=

# Hours of silence before an enrolled asset is marked stale.
AGENTGUARD_CP_STALE_HOURS=48
