{
  "name": "@pk42ac/agentguard",
  "version": "0.2.0",
  "description": "AgentOps security scanner for AI coding agents, MCP configs, transcripts, and PR diffs",
  "keywords": [
    "agentops",
    "security",
    "mcp",
    "codex",
    "claude-code",
    "scanner",
    "sarif",
    "cli"
  ],
  "homepage": "https://github.com/Sungho-pk42ac/agentguard#readme",
  "bugs": {
    "url": "https://github.com/Sungho-pk42ac/agentguard/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sungho-pk42ac/agentguard.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "examples",
    "CHANGELOG.md",
    "README.md",
    "README.en.md",
    "LICENSE"
  ],
  "directories": {
    "example": "examples"
  },
  "scripts": {
    "test": "npm run test:behavior && npm run test:docs",
    "test:behavior": "tsx --test test/*.test.ts",
    "test:docs": "tsx --test test/docs/*.test.ts",
    "build": "tsc",
    "postbuild": "node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "author": "Sungho-pk42ac",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "agentguard": "dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
